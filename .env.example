# Backend runtime
PORT=3000

# Required only for Prisma CLI validation/generation. Runtime currently uses the stateful memory store.
DATABASE_URL=postgresql://user:password@localhost:5432/travelos

# Optional live Amadeus integration. Without these, the deterministic sandbox adapter is used.
AMADEUS_API_KEY=
AMADEUS_API_SECRET=
AMADEUS_BASE_URL=https://test.api.amadeus.com
